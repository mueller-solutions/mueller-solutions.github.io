---
import Button from '../common/button.astro';
import Icon from '../common/icon.astro';
---

<section class="wrapper card">
  <p class="tagline inverted">Let's Get Started</p>
  <h2 class="heading2 inverted">Ready to Take Your Web App to the Next Level?</h2>
  <p class="description">
    Whether you're ready to dive in or just want to learn more, we're here to help. Schedule a free consultation today.
    Or, download our service guide to explore your options.
  </p>
  <div class="buttons">
    <Button isSecondary slot="buttons" scheduleAppointment> Book Your Free Strategy Session </Button>
    <Button isSecondary isOutlined slot="buttons">
      <Icon name="download" />
      <span>Free Optimization Checklist</span>
    </Button>
  </div>
</section>

<style lang="scss">
  @use '../../styles/abstracts' as *;

  section {
    background-color: $color-primary-dark;
    padding: pxtorem(83) pxtorem(217);
    text-align: center;
    margin-block: pxtorem(80);
  }

  h2 {
    margin-block-end: pxtorem(14);
    padding-inline: 12.5%;
  }

  .description {
    color: $color-light;
    margin-bottom: pxtorem(33);
  }

  .buttons {
    display: inline-flex;
    flex-direction: column;
    gap: pxtorem(20);
  }
</style>
