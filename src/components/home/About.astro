---
import Button from '../common/button.astro';
---

<section class="home-about">
  <div class="wrapper">
    <div>
      <p class="tagline">Experience You Can Trust</p>
      <h2 class="heading2">Meet Florian Mueller</h2>
      <p>
        With over 20 years in web development, I've seen it all—from small agency projects to large-scale enterprise
        solutions. Now, I bring that experience to you, delivering personalized, expert consulting to help your business
        thrive. I work closely with clients to ensure every project exceeds expectations, with the goal of building
        long-term partnerships that drive success.
      </p>
      <!-- <p>
        While I currently lead the charge, my vision is to grow into a collaborative team dedicated to your success.
        Together, we can take your web app to the next level.
      </p> -->
      <Button
        onclick="Calendly.initPopupWidget({url: 'https://calendly.com/mueller-solutions/first-consultation'});return false;"
      >
        Lets Work Together
      </Button>
    </div>
    <div>
      <figure>
        <img src="/images/home/florian-mueller.webp" alt="Florian Mueller" width="477" height="505" loading="lazy" />
      </figure>
    </div>
  </div>
</section>
