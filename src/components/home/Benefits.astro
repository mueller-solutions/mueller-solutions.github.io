---
import Section from '../common/section.astro';
import CardList from '../common/card-list.astro';
import CardWithIcon from '../common/card-with-icon.astro';
---

<Section
  title="Why Choose Us?"
  tagline="See the difference we can make"
  description="Partnering with us means you'll experience significant improvements in speed, user satisfaction, and scalability. Here's what we deliver:"
>
  <CardList columns="three">
    <CardWithIcon
      noIcon
      title="Blazing Fast Performance"
      description="We optimize your app for lightning speed"
      color="blue"
      isFadeFromBottom
    />
    <CardWithIcon
      noIcon
      title="Seamless User Experience"
      description="Smooth interactions that keep users coming back"
      color="purple"
      isFadeFromBottom
    />
    <CardWithIcon
      noIcon
      title="Scalable Solutions"
      description="Architecture that grows with your business"
      color="green"
      isFadeFromBottom
    />
  </CardList>
</Section>
