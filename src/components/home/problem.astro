---
import { Image } from 'astro:assets';
---

<section class="wrapper">
  <figure>
    <Image src="/images/home/problem-statement.webp" width="699" height="484" alt="Problem with web app" />
  </figure>
  <div class="content card white shadow">
    <p class="tagline">Don't Let a Slow App Hold You Back</p>
    <h2 class="heading2">Is Your Web App Slowing You Down?</h2>
    <p>
      In today's fast-paced digital world, a slow, unresponsive web app isn't just frustrating — it's costing you users,
      conversions, and revenue. We're here to fix what's holding you back and unlock your app's full potential.
    </p>
  </div>
</section>

<style lang="scss">
  @use '../../styles/abstracts' as *;

  section {
    padding-block: pxtorem(80);

    @include mq(small) {
      display: flex;
      align-items: center;
      padding-block: pxtorem(140) pxtorem(86);
    }
  }

  figure {
    aspect-ratio: 699 / 484;
    overflow: hidden;
    border-radius: pxtorem(12);

    @include mq(small) {
      min-width: pxtorem(699);
    }

    @include mq(mobile) {
      max-width: 100%;
    }

    > img {
      width: 100%;
      height: 100%;
    }
  }

  .content {
    position: relative;
    z-index: 2;
    padding: pxtorem(42) pxtorem(20);

    @include mq(mobile) {
      margin-top: -#{pxtorem(42)};
    }

    @include mq(small) {
      padding: pxtorem(39) pxtorem(45);
      margin-inline-start: -#{pxtorem(45)};
    }
  }

  h2 {
    margin-block-end: pxtorem(14);
  }
</style>
