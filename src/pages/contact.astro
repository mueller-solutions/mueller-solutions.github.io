import HeroBase from '../components/common/hero-base.astro';
---

<MainLayout
  title="Contact Mueller Solutions | Web Development & Frontend Consulting in Austin, TX"
  description="Connect with Mueller Solutions, your go-to partner for web development, frontend consulting, and legacy application migration. Based in Austin, TX, we specialize in enhancing web performance, scalability, and speed. Reach out for expert consultation today.”"
  keywords="Mueller Solutions web development, Frontend consulting Austin, Contact Mueller Solutions, Web application consulting, Legacy app migration services, Web performance optimization, Mueller web consulting, Web development Austin"
>
  <HeroBase class="image-right fluid-height" imageUrl="/images/contact/building.webp">
